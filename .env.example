# Database (used by docker-compose and apps/api)
POSTGRES_USER=exchange
POSTGRES_PASSWORD=exchange
POSTGRES_DB=exchange
POSTGRES_PORT=5432
DATABASE_URL=postgresql://exchange:exchange@localhost:5432/exchange

# API
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Web (NEXT_PUBLIC_ vars are exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_GITHUB_URL=https://github.com/Dalinte/exchange_demo
NEXT_PUBLIC_API_DOCS_URL=http://localhost:3001/api/docs
NEXT_PUBLIC_DOCS_URL=http://localhost:3001/api/docs
