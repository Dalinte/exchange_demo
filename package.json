{
  "name": "demo-exchange",
  "version": "0.0.0",
  "private": true,
  "description": "Cryptocurrency exchange with paper trading, no registration.",
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
